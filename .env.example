# Google OAuth2 (for Gmail + Calendar)
# Create credentials at https://console.cloud.google.com/apis/credentials
# Enable Gmail API and Google Calendar API
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://your-app.railway.app/auth/google/callback

# App URL — used for OAuth redirect after login
# Local: http://localhost:5173  |  Production: https://your-app.railway.app
APP_URL=https://your-app.railway.app

# Slack Bot Token
# Create at https://api.slack.com/apps — needs channels:read scope
SLACK_BOT_TOKEN=

# Notion Integration
# Create at https://www.notion.so/my-integrations
# Share the accounts database with the integration
NOTION_API_KEY=
NOTION_DATABASE_ID=

# Close CRM
CLOSE_API_KEY=

# Local accounts folder (optional — not available in cloud deployments)
ACCOUNTS_DIR=~/GOAL/My Accounts
