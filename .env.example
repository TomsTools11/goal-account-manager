# Google OAuth2 (for Gmail + Calendar)
# Create credentials at https://console.cloud.google.com/apis/credentials
# Enable Gmail API and Google Calendar API
# Add http://localhost:3001/auth/google/callback as authorized redirect URI
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/auth/google/callback

# Slack Bot Token
# Create at https://api.slack.com/apps — needs channels:read scope
SLACK_BOT_TOKEN=

# Notion Integration
# Create at https://www.notion.so/my-integrations
# Share the accounts database with the integration
NOTION_API_KEY=
NOTION_DATABASE_ID=

# Close CRM
CLOSE_API_KEY=

# Local accounts folder (optional)
ACCOUNTS_DIR=~/GOAL/My Accounts
